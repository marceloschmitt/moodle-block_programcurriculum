{{!
    @template block_programcurriculum/manage

    Example context (json):
    {
        "hascurricula": true,
        "curricula": [],
        "automaticmappingurl": "https://example.org",
        "modaltitle": "Example curriculum",
        "formhtml": "<form id=\"programcurriculum-curriculum-form\" method=\"post\" action=\"#\"><p></p></form>"
    }
}}

<div class="programcurriculum-manage">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h4 class="mb-0">{{#str}}listofprograms, block_programcurriculum{{/str}}</h4>
    </div>

    {{#validationerror}}
        <div class="alert alert-danger">{{validationmessage}}</div>
    {{/validationerror}}

    <div class="mb-2 d-flex flex-wrap gap-1">
        <button class="btn btn-primary" type="button" data-action="add-curriculum" data-bs-toggle="modal" data-bs-target="#programcurriculum-curriculum-modal">
            {{#str}}addcurriculum, block_programcurriculum{{/str}}
        </button>
        {{#hascurricula}}
            <a class="btn btn-secondary" href="{{automaticmappingurl}}">{{#str}}automaticmapping, block_programcurriculum{{/str}}</a>
        {{/hascurricula}}
        <button class="d-none" type="button" data-open-curriculum-modal="1" data-bs-toggle="modal" data-bs-target="#programcurriculum-curriculum-modal"></button>
    </div>

    {{#hascurricula}}
        <ul class="list-unstyled">
            {{#curricula}}
                <li class="d-flex align-items-center py-1 border-bottom">
                    <span class="text-muted me-2">{{position}}</span>
                    <span class="flex-grow-1">{{name}} ({{externalcode}}) <span class="text-muted ms-2">({{coursecount}})</span></span>
                    <div class="dropdown">
                        <button class="btn btn-link p-0 text-decoration-none" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{#str}}actions{{/str}}">
                            {{#pix}}i/moremenu, core{{/pix}}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item"
                                   href="{{editurl}}"
                                   data-action="edit-curriculum"
                                   data-edit-id="{{id}}"
                                   data-edit-name="{{editname}}"
                                   data-edit-code="{{editcode}}"
                                   data-edit-description="{{editdescription}}">
                                    {{#str}}edit{{/str}}
                                </a>
                            </li>
                            <li><a class="dropdown-item" href="{{coursesurl}}">{{#str}}courses, block_programcurriculum{{/str}}</a></li>
                            {{#hascourses}}
                                <li><a class="dropdown-item"
                                    href="{{deleteallcoursesurl}}"
                                    data-confirm-title="{{{deleteallcoursestitle_attr}}}"
                                    data-confirm-message="{{{deleteallcoursesconfirm_attr}}}">{{#str}}deleteallcourses, block_programcurriculum{{/str}}</a></li>
                            {{/hascourses}}
                            {{#candelete}}
                                <li><a class="dropdown-item"
                                    href="{{deleteurl}}"
                                    data-confirm-message="{{deleteconfirm}}"
                                    data-confirm-name="{{name}}">{{#str}}delete{{/str}}</a></li>
                            {{/candelete}}
                            {{^candelete}}
                                <li><span class="dropdown-item disabled" aria-disabled="true">{{#str}}delete{{/str}}</span></li>
                            {{/candelete}}
                        </ul>
                    </div>
                </li>
            {{/curricula}}
        </ul>
    {{/hascurricula}}

    {{^hascurricula}}
        <div class="alert alert-info">{{#str}}nocurricula, block_programcurriculum{{/str}}</div>
    {{/hascurricula}}

    <div class="modal fade" id="programcurriculum-curriculum-modal" tabindex="-1" aria-labelledby="programcurriculum-curriculum-modal-title" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="programcurriculum-curriculum-modal-title"
                        data-add-title="{{#str}}addcurriculum, block_programcurriculum{{/str}}"
                        data-edit-title="{{#str}}editcurriculum, block_programcurriculum{{/str}}">
                        {{#modaltitle}}{{modaltitle}}{{/modaltitle}}{{^modaltitle}}&nbsp;{{/modaltitle}}
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{#str}}cancel, moodle{{/str}}"></button>
                </div>
                <div class="modal-body">
                    {{{formhtml}}}
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" form="programcurriculum-curriculum-form">{{#str}}savechanges{{/str}}</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{#str}}cancel, moodle{{/str}}</button>
                </div>
            </div>
        </div>
    </div>
</div>
