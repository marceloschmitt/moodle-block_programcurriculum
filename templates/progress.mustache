<div class="programcurriculum-progress" data-course-id="{{courseid}}" data-completed-str="{{#str}}completed, block_programcurriculum{{/str}}" data-notcompleted-str="{{#str}}notcompleted, block_programcurriculum{{/str}}">
    <h2 class="mb-2">{{#str}}studentprogress, block_programcurriculum{{/str}} - {{studentname}}</h2>
    {{#hasprogramname}}
        <h3 class="mb-3">{{programname}}</h3>
    {{/hasprogramname}}

    <p class="programcurriculum-progress-intro text-muted mb-4">{{#str}}progress_intro, block_programcurriculum, {{programname}}{{/str}}</p>
    <p class="programcurriculum-progress-note text-muted small mb-4">{{#str}}progress_optional_notincluded, block_programcurriculum{{/str}}</p>

    {{#progress}}
    <div class="programcurriculum-progress-wheels d-flex flex-wrap gap-4 mt-3 mb-3">
        <div class="programcurriculum-progress-wheel" role="progressbar" aria-valuenow="{{percent}}" aria-valuemin="0" aria-valuemax="100" title="{{#str}}progressbycompletion, block_programcurriculum{{/str}}: {{percent}}% ({{completed}}/{{total}})">
            <div class="programcurriculum-progress-wheel-circle" style="--p: {{percent}};">
                <span class="programcurriculum-progress-wheel-value">{{percent}}%</span>
            </div>
            <div class="programcurriculum-progress-wheel-label small fw-bold mt-1">{{#str}}progressbycompletion_header, block_programcurriculum{{/str}}</div>
            <div class="programcurriculum-progress-wheel-detail small text-muted">{{completed}}/{{total}}</div>
        </div>
        <div class="programcurriculum-progress-wheel programcurriculum-progress-wheel--enrollment" role="progressbar" aria-valuenow="{{enrollmentpercent}}" aria-valuemin="0" aria-valuemax="100" title="{{#str}}progressbyenrollment, block_programcurriculum{{/str}}: {{enrollmentpercent}}% ({{enrolleddisciplines}}/{{totaldisciplines}})">
            <div class="programcurriculum-progress-wheel-circle" style="--p: {{enrollmentpercent}};">
                <span class="programcurriculum-progress-wheel-value">{{enrollmentpercent}}%</span>
            </div>
            <div class="programcurriculum-progress-wheel-label small fw-bold mt-1">{{#str}}progressbyenrollment_header, block_programcurriculum{{/str}}</div>
            <div class="programcurriculum-progress-wheel-detail small text-muted">{{enrolleddisciplines}}/{{totaldisciplines}}</div>
        </div>
    </div>
    {{/progress}}

    <div class="programcurriculum-progress-legend mb-4 p-3 bg-light rounded d-flex flex-wrap gap-4 align-items-center">
        <span class="programcurriculum-progress-legend-title fw-semibold">{{#str}}progresslegend, block_programcurriculum{{/str}}</span>
        <span class="d-inline-flex align-items-center gap-2">
            <span class="programcurriculum-legend-swatch programcurriculum-legend-completed programcurriculum-legend-swatch-lg" aria-hidden="true"></span>
            <span>{{#str}}progresslegend_completed, block_programcurriculum{{/str}}</span>
        </span>
        <span class="d-inline-flex align-items-center gap-2">
            <span class="programcurriculum-legend-swatch programcurriculum-legend-active programcurriculum-legend-swatch-lg" aria-hidden="true"></span>
            <span>{{#str}}progresslegend_active, block_programcurriculum{{/str}}</span>
        </span>
        <span class="d-inline-flex align-items-center gap-2">
            <span class="programcurriculum-legend-swatch programcurriculum-legend-ended programcurriculum-legend-swatch-lg" aria-hidden="true"></span>
            <span>{{#str}}progresslegend_ended, block_programcurriculum{{/str}}</span>
        </span>
    </div>

    {{#termsections}}
    <div class="mb-4">
        <h5 class="mb-2 text-secondary">{{#str}}term, block_programcurriculum{{/str}} {{term}}{{#canmark}} <span class="fw-normal text-muted small">({{#str}}markdisciplinescompleted, block_programcurriculum{{/str}})</span>{{/canmark}}</h5>
        <ul class="list-unstyled mt-2">
        {{#courserows}}
            <li class="py-1 border-bottom d-flex align-items-center flex-wrap gap-1 {{#hasmoodle}}programcurriculum-row-clickable{{/hasmoodle}} {{#row_completed}}programcurriculum-row-completed{{/row_completed}} {{#row_active}}programcurriculum-row-active{{/row_active}} {{#row_ended}}programcurriculum-row-ended{{/row_ended}}" {{#hasmoodle}}data-external-name="{{externalcoursename}}" data-moodlecourses="{{moodlecoursesjson}}" role="button" tabindex="0" aria-label="{{#str}}moodlecoursesforexternal, block_programcurriculum, {{externalcoursename}}{{/str}}"{{/hasmoodle}}>
                <span class="flex-grow-1">{{externalcoursename}}{{#hasmoodle}} <span class="text-muted">({{moodlecount}})</span>{{/hasmoodle}}</span>
                {{#canmark}}
                <label class="d-flex align-items-center mb-0 me-2" onclick="event.stopPropagation();">
                    <input type="checkbox" class="programcurriculum-user-completion" data-external-course-id="{{externalcourseid}}" {{#usermarked}}checked{{/usermarked}} aria-label="{{#str}}markascompleted, block_programcurriculum{{/str}}">
                </label>
                {{/canmark}}
            </li>
        {{/courserows}}
        </ul>
    </div>
    {{/termsections}}

    <button class="d-none" type="button" id="programcurriculum-moodle-modal-trigger" data-bs-toggle="modal" data-bs-target="#programcurriculum-moodle-modal"></button>
    <div class="modal fade" id="programcurriculum-moodle-modal" tabindex="-1" aria-labelledby="programcurriculum-moodle-modal-title" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="programcurriculum-moodle-modal-title"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{#str}}close, block_programcurriculum{{/str}}"></button>
                </div>
                <div class="modal-body" id="programcurriculum-moodle-modal-body">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{#str}}close, block_programcurriculum{{/str}}</button>
                </div>
            </div>
        </div>
    </div>
</div>
