<div class="programcurriculum-students">
    {{#hassubtitle}}
        <h2 class="mb-2">{{programname}}</h2>
    {{/hassubtitle}}
    <p class="mb-3 text-muted">{{#str}}clickstudentprogress, block_programcurriculum{{/str}}</p>
    {{#hascurricula}}
        {{#hasstudents}}
        <div class="programcurriculum-students-table-wrap table-responsive mt-2">
            <table class="table table-hover table-sm programcurriculum-students-table mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="programcurriculum-col-name">{{#str}}student, block_programcurriculum{{/str}}</th>
                        <th scope="col" class="programcurriculum-col-completion text-nowrap">{{#str}}progressbycompletion_header, block_programcurriculum{{/str}}</th>
                        <th scope="col" class="programcurriculum-col-enrollment text-nowrap">{{#str}}progressbyenrollment_header, block_programcurriculum{{/str}}</th>
                        <th scope="col" class="programcurriculum-col-subscriptions text-nowrap">{{#str}}currentenrollment, block_programcurriculum{{/str}}</th>
                    </tr>
                </thead>
                <tbody>
                {{#students}}
                    <tr>
                        <td class="programcurriculum-col-name align-middle">
                            <a href="{{viewurl}}">{{fullname}}</a>
                        </td>
                        <td class="programcurriculum-col-completion align-middle">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress programcurriculum-student-progress"
                                    style="height: 0.75rem; min-width: 80px;"
                                    role="progressbar"
                                    aria-valuenow="{{progresspercent}}"
                                    aria-valuemin="0"
                                    aria-valuemax="100"
                                    title="{{progresspercent}}%">
                                    <div class="progress-bar" style="width: {{progresspercent}}%"></div>
                                </div>
                                <span class="text-muted small" style="min-width: 2.25rem;">{{progresspercent}}%</span>
                            </div>
                        </td>
                        <td class="programcurriculum-col-enrollment align-middle">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress programcurriculum-student-progress"
                                    style="height: 0.75rem; min-width: 80px;"
                                    role="progressbar"
                                    aria-valuenow="{{enrollmentpercent}}"
                                    aria-valuemin="0"
                                    aria-valuemax="100"
                                    title="{{enrollmentpercent}}%">
                                    <div class="progress-bar bg-info" style="width: {{enrollmentpercent}}%"></div>
                                </div>
                                <span class="text-muted small" style="min-width: 2.25rem;">{{enrollmentpercent}}%</span>
                            </div>
                        </td>
                        <td class="programcurriculum-col-subscriptions align-middle text-muted">
                            {{enrolledcount}}
                        </td>
                    </tr>
                {{/students}}
                </tbody>
            </table>
        </div>
        {{/hasstudents}}
        {{^hasstudents}}
        <div class="alert alert-info mt-3">{{#str}}nostudents, block_programcurriculum{{/str}}</div>
        {{/hasstudents}}
    {{/hascurricula}}

    {{^hascurricula}}
        <div class="alert alert-info">{{#str}}nocurricula, block_programcurriculum{{/str}}</div>
    {{/hascurricula}}
</div>
