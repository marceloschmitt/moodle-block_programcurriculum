<div class="programcurriculum-students">
    {{#hassubtitle}}
        <h2 class="mb-2">{{programname}}</h2>
    {{/hassubtitle}}
    <p class="mb-3 text-muted">{{#str}}clickstudentprogress, block_programcurriculum{{/str}}</p>
    {{#hascurricula}}
        {{#hasstudents}}
        <ul class="list-unstyled mt-2">
        {{#students}}
            <li class="py-2 border-bottom d-flex flex-wrap align-items-center gap-2">
                <a href="{{viewurl}}" class="me-2">{{fullname}}</a>
                <span class="d-inline-flex align-items-center gap-2 flex-grow-1">
                    <span class="programcurriculum-student-progress-bar-wrap d-inline-flex align-items-center gap-1" style="min-width: 120px;">
                        <div class="progress flex-grow-1" style="height: 0.75rem; min-width: 60px;" role="progressbar" aria-valuenow="{{progresspercent}}" aria-valuemin="0" aria-valuemax="100" title="{{#str}}progressbycompletion, block_programcurriculum{{/str}}: {{progresspercent}}%">
                            <div class="progress-bar" style="width: {{progresspercent}}%"></div>
                        </div>
                        <span class="small text-muted" style="min-width: 2.5rem;">{{progresspercent}}%</span>
                    </span>
                    <span class="small text-muted">{{#str}}currentdisciplinescount, block_programcurriculum{{/str}} {{enrolledcount}}</span>
                </span>
            </li>
        {{/students}}
        </ul>
        {{/hasstudents}}
        {{^hasstudents}}
        <div class="alert alert-info mt-3">{{#str}}nostudents, block_programcurriculum{{/str}}</div>
        {{/hasstudents}}
    {{/hascurricula}}

    {{^hascurricula}}
        <div class="alert alert-info">{{#str}}nocurricula, block_programcurriculum{{/str}}</div>
    {{/hascurricula}}
</div>
