{{!
    @template block_programcurriculum/course

    Example context (json):
    {
        "curriculumid": "1",
        "sesskey": "sess",
        "curriculumname": "Example curriculum",
        "backurl": "https://example.org",
        "hascourses": true,
        "termsections": [],
        "modaltitle": "Example course",
        "formhtml": "<form id=\"programcurriculum-course-form\" method=\"post\" action=\"#\"><p></p></form>",
        "automaticurl": "https://example.org",
        "assistedmappingurl": "https://example.org"
    }
}}

<div class="programcurriculum-course" data-curriculum-id="{{curriculumid}}" data-sesskey="{{sesskey}}">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h4 class="mb-0">{{#str}}listofcourses, block_programcurriculum{{/str}} - {{curriculumname}}</h4>
        <a class="btn btn-secondary" href="{{backurl}}">{{#str}}backtoprograms, block_programcurriculum{{/str}}</a>
    </div>

    {{#validationerror}}
        <div class="alert alert-danger">{{validationmessage}}</div>
    {{/validationerror}}

    <div class="mb-2">
        <button class="btn btn-primary" type="button" data-action="add-course" data-bs-toggle="modal" data-bs-target="#programcurriculum-course-modal">
            {{#str}}addcourse, block_programcurriculum{{/str}}
        </button>
        <a class="btn btn-secondary" href="{{automaticurl}}">{{#str}}automaticmapping, block_programcurriculum{{/str}}</a>
        <a class="btn btn-secondary" href="{{assistedmappingurl}}">{{#str}}assistedmapping, block_programcurriculum{{/str}}</a>
        <button class="d-none" type="button" data-open-course-modal="1" data-bs-toggle="modal" data-bs-target="#programcurriculum-course-modal"></button>
    </div>

    {{#termsections}}
        <div class="mb-4 programcurriculum-term-section" data-term="{{term}}">
            <h5 class="mb-2 text-secondary">{{#str}}term, block_programcurriculum{{/str}} {{term}}</h5>
            <ul class="list-unstyled programcurriculum-term-list">
                {{#courses}}
                <li class="d-flex align-items-center py-1 border-bottom programcurriculum-course-item"
                    data-course-id="{{id}}"
                    data-position="{{position}}"
                    data-term="{{editterm}}">
                    <span class="text-muted me-2">{{position}}</span>
                    <span class="flex-grow-1">{{externalcode}} - {{name}} <span class="text-muted ms-2">({{mappingcount}})</span></span>
                    <div class="dropdown">
                        <button class="btn btn-link p-0 text-decoration-none" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{#str}}actions{{/str}}">
                            {{#pix}}i/moremenu, core{{/pix}}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item"
                                   href="{{editurl}}"
                                   data-action="edit-course"
                                   data-edit-id="{{id}}"
                                   data-edit-name="{{editname}}"
                                   data-edit-code="{{editcode}}"
                                   data-edit-equivalencecode="{{editequivalencecode}}"
                                   data-edit-sortorder="{{editsortorder}}"
                                   data-edit-term="{{editterm}}"
                                   data-edit-curriculum="{{curriculumid}}">
                                    {{#str}}edit{{/str}}
                                </a>
                            </li>
                            <li><a class="dropdown-item" href="{{mappingurl}}">{{#str}}mappings, block_programcurriculum{{/str}}</a></li>
                            <li>
                                <a class="dropdown-item programcurriculum-move-trigger"
                                    href="#"
                                    data-move-course-id="{{id}}"
                                    data-move-target="{{moveactionurl}}"
                                    data-move-name="{{name}}"
                                    data-current-position="{{position}}"
                                    data-max-position="{{totalpositions}}">
                                    {{#str}}move, block_programcurriculum{{/str}}
                                </a>
                            </li>
                            {{#candelete}}
                                <li><a class="dropdown-item"
                                    href="{{deleteurl}}"
                                    data-confirm-message="{{deleteconfirm}}"
                                    data-confirm-name="{{name}}">{{#str}}delete{{/str}}</a></li>
                            {{/candelete}}
                            {{^candelete}}
                                <li><span class="dropdown-item disabled" aria-disabled="true">{{#str}}delete{{/str}}</span></li>
                            {{/candelete}}
                        </ul>
                    </div>
                </li>
                {{/courses}}
                {{^courses}}
                <li class="programcurriculum-term-empty py-2 text-muted small">{{#str}}nocourses, block_programcurriculum{{/str}}</li>
                {{/courses}}
            </ul>
        </div>
    {{/termsections}}

    {{^hascourses}}
        <div class="alert alert-info">{{#str}}nocourses, block_programcurriculum{{/str}}</div>
    {{/hascourses}}

    <div class="modal fade" id="programcurriculum-course-modal" tabindex="-1" aria-labelledby="programcurriculum-course-modal-title" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="programcurriculum-course-modal-title"
                        data-add-title="{{#str}}addcourse, block_programcurriculum{{/str}}"
                        data-edit-title="{{#str}}editcourse, block_programcurriculum{{/str}}">
                        {{#modaltitle}}{{modaltitle}}{{/modaltitle}}{{^modaltitle}}&nbsp;{{/modaltitle}}
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{#str}}cancel, moodle{{/str}}"></button>
                </div>
                <div class="modal-body">
                    {{{formhtml}}}
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" form="programcurriculum-course-form">{{#str}}savechanges{{/str}}</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{#str}}cancel, moodle{{/str}}</button>
                </div>
            </div>
        </div>
    </div>
</div>
