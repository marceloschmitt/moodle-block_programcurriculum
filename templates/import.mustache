<div class="programcurriculum-import">
    <div class="alert alert-info">{{helptext}}</div>

    {{#showimportedsuccess}}
        <div class="alert alert-success">
            {{#str}}import_success, block_programcurriculum, {{importedcount}}{{/str}}
        </div>
    {{/showimportedsuccess}}

    {{#haserrors}}
        <div class="alert alert-danger">
            <strong>{{#str}}importerrors, block_programcurriculum{{/str}}</strong>
            <ul>
                {{#errors}}
                    <li>{{.}}</li>
                {{/errors}}
            </ul>
        </div>
    {{/haserrors}}

    {{#showpreview}}
        <div class="programcurriculum-import-preview card mt-3">
            <div class="card-header">
                <strong>{{#str}}importtext_preview_title, block_programcurriculum{{/str}}</strong>
            </div>
            <div class="card-body">
                {{#preview.programs}}
                    <div class="programcurriculum-import-program mb-4">
                        <p class="mb-2"><strong>{{programname}} — {{programcode}} — {{termcount}}</strong></p>
                        <ul class="list-unstyled ml-2 mt-1">
                            {{#terms}}
                                {{#courses}}
                                    <li>{{#code}}{{code}} — {{/code}}{{name}} — {{term}}</li>
                                {{/courses}}
                            {{/terms}}
                        </ul>
                    </div>
                    {{^last}}<hr class="my-3">{{/last}}
                {{/preview.programs}}
                <p class="text-muted small mt-2">{{#str}}importtext_preview_nosave, block_programcurriculum{{/str}}</p>
            </div>
        </div>
    {{/showpreview}}
</div>
