<div class="programcurriculum-import">
    <div class="alert alert-info">{{helptext}}</div>

    {{#haserrors}}
        <div class="alert alert-danger">
            <strong>{{#str}}importerrors, block_programcurriculum{{/str}}</strong>
            <ul>
                {{#errors}}
                    <li>{{.}}</li>
                {{/errors}}
            </ul>
        </div>
    {{/haserrors}}

    {{#showpreview}}
        <div class="programcurriculum-import-preview card mt-3">
            <div class="card-header">
                <strong>{{#str}}importtext_preview_title, block_programcurriculum{{/str}}</strong>
            </div>
            <div class="card-body">
                {{#preview.programs}}
                    <div class="programcurriculum-import-program mb-4">
                        <p class="mb-2"><strong>{{#str}}curriculumname, block_programcurriculum{{/str}}:</strong> {{programname}}</p>
                        <p class="mb-2 small text-muted">{{#str}}curriculumcode, block_programcurriculum{{/str}}: {{programcode}}</p>
                        <p class="mb-2 small text-muted">{{#str}}importtext_terms_count, block_programcurriculum{{/str}}: {{termcount}}</p>
                        {{#terms}}
                            <div class="programcurriculum-import-term mb-3 ml-2">
                                <strong>{{#str}}term, block_programcurriculum{{/str}} {{term}} — {{label}}</strong>
                                <ul class="list-unstyled ml-3 mt-1">
                                    {{#courses}}
                                        <li>{{#code}}{{code}} — {{/code}}{{name}} — {{term}}</li>
                                    {{/courses}}
                                </ul>
                            </div>
                        {{/terms}}
                    </div>
                    {{^last}}<hr class="my-3">{{/last}}
                {{/preview.programs}}
                <p class="text-muted small mt-2">{{#str}}importtext_preview_nosave, block_programcurriculum{{/str}}</p>
            </div>
        </div>
    {{/showpreview}}
</div>
